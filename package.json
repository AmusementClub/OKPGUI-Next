{
  "name": "okpgui-next",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "version:sync": "node scripts/sync-version.mjs",
    "predev": "node scripts/sync-version.mjs",
    "dev": "vite",
    "test": "vitest run --environment jsdom --exclude 'tests/ui-integration/**'",
    "test:ui-integration": "node scripts/run-playwright-ui-integration.mjs",
    "test:provider-contract": "node scripts/verify-provider-contract.mjs",
    "test:security-offline": "node scripts/verify-provider-contract.mjs && node scripts/verify-ui-integration-inventory.mjs",
    "verify:mediainfo": "node scripts/verify-mediainfo-package.mjs --manifest-only",
    "verify:byok-release-gates": "node scripts/verify-byok-release-gates.mjs",
    "verify:ui-integration-inventory": "node scripts/verify-ui-integration-inventory.mjs",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pretauri": "node scripts/sync-version.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@headlessui/react": "^2.2.9",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@yaireo/tagify": "^4.36.0",
    "dompurify": "^3.4.1",
    "easymde": "^2.20.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
